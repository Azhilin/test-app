# =============================================================================
# Non-sensitive project defaults — committed to version control.
# These values apply to all developers who clone this repo.
# To override any value locally, add the key to your .env file.
# Secrets (JIRA_URL, JIRA_EMAIL, JIRA_API_TOKEN) live in .env, not here.
# =============================================================================


# =============================================================================
# Dev Environment
# =============================================================================

# Suppress Python bytecode generation (keeps __pycache__ dirs out of the project root).
# Safe for this project — no startup-time performance benefit from .pyc files.
PYTHONDONTWRITEBYTECODE=1


# =============================================================================
# Report Scope
# Controls which board, sprints, and teams are included in the report.
# =============================================================================

# Number of past sprints to analyse (default: 10)
JIRA_SPRINT_COUNT=10

# Agile board ID (numeric). Find it in the board URL: .../boards/42
# Required — the app cannot guess which board to use when multiple boards exist.
# Example: JIRA_BOARD_ID=42
JIRA_BOARD_ID=1

# Jira project key(s), comma-separated. Visible in every issue key — e.g. MYTEAM in MYTEAM-123.
# You do not need admin access to find this.
# Sets the JQL clause: project IN (MYTEAM, OTHERPROJ)
# Note: this is the Jira project key, unrelated to PROJECT_TYPE (methodology) below.
# Example: JIRA_PROJECT=MYTEAM
# Example: JIRA_PROJECT=MYTEAM,OTHERPROJ
JIRA_PROJECT=

# Team UUID(s), comma-separated. Used with the Team[Team] custom field in JQL.
# Find it in the board URL when you filter by team: .../boards?team=<uuid>
# Example: JIRA_TEAM_ID=abc123-def4-5678-ghij-000000000000
# JIRA_TEAM_ID=

# Schema name from config/jira_schema.json. Must match "schema_name" exactly.
# Default when unset: Default_Jira_Cloud — the shipped entry in that file.
JIRA_SCHEMA_NAME=Default_Jira_Cloud


# =============================================================================
# Issue Filter (JQL)
# Narrows which issues are included when fetching sprint data.
# All fields below combine into a single JQL query alongside the sprint clause.
# =============================================================================

# Issue types to include, comma-separated.
# Visible on any Jira issue in the "Issue type" field.
# Example: JIRA_ISSUE_TYPES=Story,Bug,Task
# JIRA_ISSUE_TYPES=

# Only include issues from closed sprints (default: true)
# Set to false to also include the active sprint.
JIRA_CLOSED_SPRINTS_ONLY=false

# ID of a saved Jira filter. Only issues matching that filter's JQL are included.
# Find it in the URL when you open a saved filter: .../issues/?filter=12345
# Use this when JIRA_PROJECT is not set or when you need complex JQL you already
# maintain in Jira. JIRA_PROJECT takes precedence when both are set.
# Example: JIRA_FILTER_ID=12345
JIRA_FILTER_ID=

# Issues fetched per page when using the Filter ID path (1–100, default: 100)
JIRA_FILTER_PAGE_SIZE=100


# =============================================================================
# AI Adoption Labels
# Add these labels in Jira to track AI-assisted work.
# Labels are case-sensitive and must match exactly.
# =============================================================================

# Label that marks an issue as AI-assisted (default: AI_assistance)
AI_ASSISTED_LABEL=ai_assisted

# Comma-separated labels whose issues are excluded from the AI % denominator.
# Use for non-delivery work such as spikes or admin tickets.
# Example: AI_EXCLUDE_LABELS=spike,admin,tech-debt
AI_EXCLUDE_LABELS=ai_not_applicable

# Comma-separated labels identifying AI tools used (e.g. Copilot, ChatGPT)
# One label per tool; an issue can carry multiple tool labels.
# Example: AI_TOOL_LABELS=AI_Tool_Copilot,AI_Tool_ChatGPT,AI_Tool_Gemini,AI_Tool_Cursor
AI_TOOL_LABELS=gemini,github_copilot,rovo

# Comma-separated labels identifying AI use-cases (e.g. code generation, review)
# Example: AI_ACTION_LABELS=AI_Case_CodeGen,AI_Case_Review,AI_Case_Testing,AI_Case_Docs,AI_Case_Refactor
AI_ACTION_LABELS=ai_automation,ai_dev,ai_test,ai_test_cases


# =============================================================================
# Report Generation
# Controls project methodology, estimation approach, and which metric sections
# appear in generated reports.
# =============================================================================

# Project methodology: SCRUM or KANBAN (default: SCRUM)
# SCRUM uses board sprints; KANBAN groups issues by calendar month.
# Note: this is the methodology, unrelated to JIRA_PROJECT (project key) above.
PROJECT_TYPE=SCRUM

# Estimation type: StoryPoints or JiraTickets (default: StoryPoints)
# StoryPoints sums story-point values; JiraTickets counts done issues.
ESTIMATION_TYPE=StoryPoints

# Metric section toggles (true/false, all default: true)
# Set to false to exclude a section from generated reports.
METRIC_VELOCITY=true
METRIC_AI_ASSISTANCE_TREND=false
METRIC_AI_USAGE_DETAILS=false
METRIC_DAU=false
METRIC_DAU_TREND=false


# =============================================================================
# Confluence
# Optional. Enables publishing reports to Confluence pages.
# Confluence integration is forward-declared here; full wiring is in progress.
# Confluence credentials (CONFLUENCE_EMAIL, CONFLUENCE_API_TOKEN) live in .env.
# =============================================================================

# Confluence base URL. For Atlassian Cloud add /wiki after your domain.
# Example: CONFLUENCE_URL=https://your-domain.atlassian.net/wiki
# Example: CONFLUENCE_URL=https://confluence.your-company.com
# CONFLUENCE_URL=

# Confluence space key where reports or documentation pages are published.
# Visible in the URL of any space: .../wiki/spaces/MYSPACE/...
# Use ~username for a personal space.
# Example: CONFLUENCE_SPACE_KEY=TEAM
# Example: CONFLUENCE_SPACE_KEY=~john.doe
# CONFLUENCE_SPACE_KEY=


# =============================================================================
# Server
# =============================================================================

# Local dev server port (default: 8080)
PORT=8080
