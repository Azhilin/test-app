# Jira Cloud base URL (e.g. https://your-domain.atlassian.net)
JIRA_URL=

# Email used for Jira / Atlassian account
JIRA_EMAIL=

# API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# Optional: Board ID for Agile/Scrum (numeric). If unset, first board is used.
# JIRA_BOARD_ID=

# Optional: Number of past sprints to include (default: 10)
# JIRA_SPRINT_COUNT=10

# Optional: Story points custom field ID (default: customfield_10016)
# JIRA_STORY_POINTS_FIELD=customfield_10016

# Optional: Jira saved filter ID. Only issues matching this filter are included in the report.
# JIRA_FILTER_ID=

# Optional: Local server port (default: 8080)
# PORT=8080

# SSL / TLS Certificate
# Run once to cache the Jira host's TLS certificate in certs/jira_ca_bundle.pem.
# The Jira API client will use it automatically for all connections.
#   python tools/fetch_ssl_cert.py
# You can also click "Fetch Certificate" on the Jira Connection tab in the UI.

# AI Adoption metrics labels
# Label that marks an issue as AI-assisted (default: AI_assistance)
# AI_ASSISTED_LABEL=AI_assistance

# Comma-separated labels whose issues are excluded from the AI% denominator
# AI_EXCLUDE_LABELS=

# Comma-separated labels identifying AI tools used (e.g. Copilot, ChatGPT)
# AI_TOOL_LABELS=AI_Tool_Copilot,AI_Tool_ChatGPT,AI_Tool_Gemini

# Comma-separated labels identifying AI use-cases (e.g. code generation, review)
# AI_ACTION_LABELS=AI_Case_CodeGen,AI_Case_Review,AI_Case_Testing
